{
  "name": "fieldmark",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first invoice extraction, evidence review, and validation workspace.",
  "license": "MIT",
  "author": "AkhilTrivediX",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkhilTrivediX/FieldMark.git"
  },
  "engines": {
    "node": ">=20.19"
  },
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:fixtures": "vitest run src/fixtures.test.ts",
    "test:all": "pnpm test && pnpm typecheck && pnpm build",
    "fixtures:generate": "node scripts/generate-fixtures.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
